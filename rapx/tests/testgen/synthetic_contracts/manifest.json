{
  "description": "Synthetic benchmark crates for contract-guided Rust test generation.",
  "design": "The suite is organized by trigger mechanism rather than only by safety-property family. Public-field cases are kept as a small baseline; most crates require method mutation, ordered state propagation, constructor flow, resource recipes, generic choices, or post-call hazards.",
  "crates": [
    {
      "name": "pointer_inbound_index",
      "family": "Pointer",
      "sp": ["InBound"],
      "unsafe_api": "core::slice::get_unchecked",
      "trigger": "public-field baseline",
      "mutator": "public field idx"
    },
    {
      "name": "pointer_dangling_read",
      "family": "Pointer",
      "sp": ["ValidPtr", "Allocated", "Init"],
      "unsafe_api": "core::ptr::read",
      "trigger": "public-field resource baseline",
      "mutator": "public field ptr"
    },
    {
      "name": "cgag_field_mutation",
      "family": "Pointer",
      "sp": ["InBound"],
      "unsafe_api": "core::slice::get_unchecked",
      "trigger": "method-or-public direct state mutation",
      "mutator": "set_idx or public field idx"
    },
    {
      "name": "method_utf8_setter",
      "family": "Content",
      "sp": ["ValidString"],
      "unsafe_api": "std::string::String::from_utf8_unchecked",
      "trigger": "method-only content mutation",
      "mutator": "replace_bytes(Vec<u8>)"
    },
    {
      "name": "method_dangling_ptr_recipe",
      "family": "Pointer",
      "sp": ["ValidPtr", "Alive", "Init"],
      "unsafe_api": "core::ptr::read",
      "trigger": "method parameter with resource recipe",
      "mutator": "set_ptr(*const i32)"
    },
    {
      "name": "ordered_two_field_index",
      "family": "Pointer",
      "sp": ["InBound"],
      "unsafe_api": "core::slice::get_unchecked",
      "trigger": "ordered two-field state propagation",
      "mutator": "set_pending_idx then commit_idx"
    },
    {
      "name": "derived_index_protocol",
      "family": "Pointer",
      "sp": ["InBound"],
      "unsafe_api": "core::slice::get_unchecked",
      "trigger": "derived target field with transformed inputs",
      "mutator": "select_page/select_slot then commit"
    },
    {
      "name": "chain_typed_window_align",
      "family": "Layout",
      "sp": ["Align", "ValidPtr", "Init", "ValidNum"],
      "unsafe_api": "core::slice::from_raw_parts",
      "trigger": "ordered generic alignment protocol",
      "mutator": "select_offset then set_count::<T>"
    },
    {
      "name": "generic_align_from_raw_parts",
      "family": "Layout",
      "sp": ["Align", "ValidPtr", "Init"],
      "unsafe_api": "core::slice::from_raw_parts",
      "trigger": "constructor-induced generic alignment mismatch",
      "mutator": "new_from_buffer with high-alignment T"
    },
    {
      "name": "slice_from_raw_parts_bounds",
      "family": "Pointer",
      "sp": ["InBound", "ValidNum", "ValidPtr", "Init"],
      "unsafe_api": "core::slice::from_raw_parts",
      "trigger": "method-controlled slice object range and total-size contract",
      "mutator": "set_len(len)"
    },
    {
      "name": "local_expression_contract",
      "family": "Numeric",
      "sp": ["ValidNum"],
      "unsafe_api": "local_expression_contract::raw_len_sink",
      "trigger": "manual local unsafe API expression annotation",
      "mutator": "set_len(len)"
    },
    {
      "name": "vec_set_len_uninit",
      "family": "Initialization",
      "sp": ["Init", "ValidNum"],
      "unsafe_api": "alloc::vec::Vec::set_len and core::ptr::read",
      "trigger": "initialization protocol violation",
      "mutator": "expose_len(len)"
    },
    {
      "name": "layout_size_align_methods",
      "family": "Layout",
      "sp": ["Layout", "ValidNum", "Align"],
      "unsafe_api": "std::alloc::Layout::from_size_align_unchecked",
      "trigger": "two method-controlled numeric roles",
      "mutator": "set_size and set_align"
    },
    {
      "name": "non_overlap_copy_chain",
      "family": "AliasLifetime",
      "sp": ["NonOverlap", "ValidPtr", "Init"],
      "unsafe_api": "core::ptr::copy_nonoverlapping",
      "trigger": "multi-field overlap construction",
      "mutator": "select_src/select_dst/set_count"
    },
    {
      "name": "alias_shared_ref_hazard",
      "family": "AliasLifetime",
      "sp": ["Alias", "Alive", "ValidPtr2Ref"],
      "unsafe_api": "core::ptr::mut_ptr::as_ref",
      "trigger": "post-call alias hazard",
      "mutator": "write_through_shared after borrow"
    },
    {
      "name": "content_cstr_public",
      "family": "Content",
      "sp": ["ValidCStr"],
      "unsafe_api": "std::ffi::CStr::from_bytes_with_nul_unchecked",
      "trigger": "legacy public-field content baseline",
      "mutator": "public field bytes"
    },
    {
      "name": "content_unwrap_public",
      "family": "Content",
      "sp": ["Unwrap"],
      "unsafe_api": "core::option::Option::unwrap_unchecked",
      "trigger": "legacy public-field enum baseline",
      "mutator": "public field value"
    },
    {
      "name": "layout_align_public",
      "family": "Layout",
      "sp": ["Align"],
      "unsafe_api": "core::ptr::read",
      "trigger": "legacy public-field layout baseline",
      "mutator": "public field ptr"
    },
    {
      "name": "layout_bad_layout",
      "family": "Layout",
      "sp": ["Align", "ValidNum"],
      "unsafe_api": "std::alloc::Layout::from_size_align_unchecked",
      "trigger": "legacy public-field layout baseline",
      "mutator": "public fields size/align"
    },
    {
      "name": "alias_box_from_raw",
      "family": "AliasLifetime",
      "sp": ["NotOwned", "Allocated"],
      "unsafe_api": "std::boxed::Box::from_raw",
      "trigger": "legacy ownership baseline",
      "mutator": "public field ptr"
    }
  ]
}
